class Solution:
    def removeDuplicates(self, nums: List[int]) -> int:
        low=0
        high=1
        count=1
        while high<len(nums):
            if nums[high-1]==nums[high]:
                high+=1
                continue
            else:
                nums[low+1]=nums[high]
                low+=1
                high+=1
                count+=1
        return count
